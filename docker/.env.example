# Docker Environment Configuration for Personal AI Assistant
# Copy this to .env and configure with your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=andy
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=personal_ai

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_KEY=your-secure-api-key-here

# ============================================================================
# AI BACKEND CONFIGURATION
# ============================================================================

# Available backends (comma-separated)
# Options: claude, lmstudio, ollama, mock
AVAILABLE_BACKENDS=lmstudio,ollama,claude,mock

# Primary and secondary backends for fallback
# For GPU-accelerated setup: lmstudio → ollama → claude
# For cloud-only: claude → mock
PRIMARY_BACKEND=lmstudio
SECONDARY_BACKEND=ollama

# Backend selection strategy
BACKEND_SELECTION_STRATEGY=sequential

# ============================================================================
# CLAUDE CONFIGURATION (optional - cloud API)
# ============================================================================
# Anthropic Claude API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ============================================================================
# LM STUDIO CONFIGURATION (OpenAI-compatible local API)
# ============================================================================
# LM Studio provides GPU-accelerated inference with OpenAI-compatible API
LMSTUDIO_BASE_URL=http://192.168.7.187:1234/v1
LMSTUDIO_MODEL=local-model

# ============================================================================
# OLLAMA CONFIGURATION (local CPU inference)
# ============================================================================
# Ollama provides local inference, good for background tasks
OLLAMA_BASE_URL=http://192.168.7.187:11434
OLLAMA_MODEL=gemma3:27b

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=production
